
import os
import yt_dlp
import asyncio
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import ApplicationBuilder, CommandHandler, MessageHandler, filters, ContextTypes, CallbackQueryHandler
from shazamio import Shazam

# SIZNING TOKENINGIZ
TOKEN = "8717890222:AAEb501qDuzVglFzEKM3wAF-YwbSq9-1jDc"

# Start bosilganda chiqadigan matn
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = (
        "🔥 Assalomu alaykum. @Mixsavedibot ga Xush kelibsiz.\n"
        "Bot orqali quyidagilarni yuklab olishingiz mumkin:\n\n"
        "• Instagram - stories, post va reels + audio;\n"
        "• YouTube - videolar va shorts + audio;\n"
        "• TikTok - suv belgisiz video + audio;\n"
        "• Pinterest - suv belgisiz video va rasmlar;\n\n"
        "Shazam funksiya:\n"
        "• Ovozli xabar yoki video yuborsangiz musiqasini topib beraman!\n\n"
        "🚀 Media yuklash uchun havolasini yuboring."
    )
    await update.message.reply_text(text)

# Havola yuborilganda sifat tugmalarini chiqarish
async def handle_link(update: Update, context: ContextTypes.DEFAULT_TYPE):
    url = update.message.text
    if "http" not in url: return

    keyboard = [
        [
            InlineKeyboardButton("🎬 360p", callback_data=f"360|{url}"),
            InlineKeyboardButton("🎬 480p", callback_data=f"480|{url}")
        ],
        [
            InlineKeyboardButton("🎬 720p", callback_data=f"720|{url}"),
            InlineKeyboardButton("🎬 1080p", callback_data=f"1080|{url}")
        ],
        [InlineKeyboardButton("🎵 Audio (MP3)", callback_data=f"audio|{url}")]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    await update.message.reply_text("Sifatni tanlang:", reply_markup=reply_markup)

# Tugma bosilganda yuklash jarayoni
async def button_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    quality, url = query.data.split("|")
    await query.answer("Yuklash boshlandi...")
    
    msg = await query.message.reply_text(f"⏳ {quality} sifatda tayyorlanmoqda, kuting...")

    try:
        file_name = f"mix_{query.from_user.id}.mp4"
        if quality == "audio":
            ydl_opts = {'format': 'bestaudio/best', 'outtmpl': f"mix_{query.from_user.id}.mp3"}
            file_name = f"mix_{query.from_user.id}.mp3"
        else:
            ydl_opts = {
                'format': f'bestvideo[height<={quality}]+bestaudio/best/best',
                'outtmpl': file_name,
                'merge_output_format': 'mp4'
            }

        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            ydl.download([url])

        if quality == "audio":
            await query.message.reply_audio(audio=open(file_name, 'rb'), caption="✅ @Mixsavedibot orqali yuklandi")
        else:
            await query.message.reply_video(video=open(file_name, 'rb'), caption="✅ @Mixsavedibot orqali yuklandi")
            
        await msg.delete()
        os.remove(file_name)
    except Exception as e:
        await msg.edit_text("❌ Xatolik! Fayl juda katta yoki sifat topilmadi.")

# Shazam funksiyasi (Ovozli xabarlar uchun)
async def handle_shazam(update: Update, context: ContextTypes.DEFAULT_TYPE):
    status = await update.message.reply_text("🔍 Musiqa qidirilmoqda...")
    try:
        file = await update.message.voice.get_file() if update.message.voice else await update.message.audio.get_file()
        path = "shazam_audio.ogg"
        await file.download_to_drive(path)
        
        shazam = Shazam()
        out = await shazam.recognize_song(path)
        
        if out['matches']:
            t = out['track']
            await status.edit_text(f"✅ Topildi!\n\nNom: {t['title']}\nIjrochi: {t['subtitle']}\n\n@Mixsavedibot")
        else:
            await status.edit_text("❌ Musiqa topilmadi.")
        os.remove(path)
    except:
        await status.edit_text("❌ Xato! Ovozli xabarni tahlil qilib bo'lmadi.")

if __name__ == '__main__':
    app = ApplicationBuilder().token(TOKEN).build()
    
    app.add_handler(CommandHandler('start', start))
    app.add_handler(MessageHandler(filters.TEXT & (~filters.COMMAND), handle_link))
    app.add_handler(MessageHandler(filters.VOICE | filters.AUDIO, handle_shazam))
    app.add_handler(CallbackQueryHandler(button_callback))
    
    print("Bot @Mixsavedibot nomi bilan ishga tushdi!")
    app.run_polling()

<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mening Bozorim | Katalog</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root { --main-color: #7000ff; --accent-color: #ffbe1f; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; background: #f2f4f7; }
        
        header { background: white; padding: 15px; text-align: center; box-shadow: 0 2px 5px rgba(0,0,0,0.1); position: sticky; top: 0; z-index: 100; }
        header h1 { color: var(--main-color); margin: 0; font-size: 24px; }

        .container { max-width: 1200px; margin: 20px auto; padding: 0 10px; }
        
        /* Katalog Grid */
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 15px; }
        
        /* Mahsulot kartochkasi */
        .card { background: white; border-radius: 12px; overflow: hidden; transition: 0.3s; position: relative; display: flex; flex-direction: column; }
        .card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .card img { width: 100%; height: 200px; object-fit: cover; }
        
        .card-info { padding: 12px; flex-grow: 1; }
        .price { font-weight: bold; font-size: 18px; color: #000; margin: 5px 0; }
        .title { font-size: 14px; color: #4d4e59; height: 40px; overflow: hidden; }
        
        .btn-contact { 
            background: var(--main-color); color: white; text-align: center; 
            padding: 10px; text-decoration: none; border-radius: 8px; 
            display: block; margin-top: 10px; font-weight: 600; font-size: 14px;
        }
        .btn-contact:active { background: #5a00cc; }

        /* Admin tugmasi (shartli) */
        .admin-float { position: fixed; bottom: 20px; right: 20px; background: var(--accent-color); width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none; font-size: 30px; box-shadow: 0 4px 10px rgba(0,0,0,0.2); z-index: 1000; }
    </style>
</head>
<body>

<header>
    <h1>Mening Marketim</h1>
</header>

<div class="container">
    <div id="product-list" class="grid">
        <p>Yuklanmoqda...</p>
    </div>
</div>

<a href="admin.html" class="admin-float">➕</a>

<script>
    // Supabase sozlamalari (Buni o'zingizning Supabase URL va Key bilan almashtiring)
    const SUPABASE_URL = 'SIZNING_SUPABASE_URL';
    const SUPABASE_KEY = 'SIZNING_SUPABASE_ANON_KEY';
    const _supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

    async function getProducts() {
        let { data: products, error } = await _supabase.from('products').select('*');
        const container = document.getElementById('product-list');
        
        if (error) {
            container.innerHTML = "<p>Xatolik yuz berdi!</p>";
            return;
        }

        container.innerHTML = ""; // Tozalash
        products.forEach(item => {
            container.innerHTML += `
                <div class="card">
                    <img src="${item.image_url || 'https://via.placeholder.com/200'}" alt="${item.name}">
                    <div class="card-info">
                        <div class="price">${Number(item.price).toLocaleString()} so'm</div>
                        <div class="title">${item.name}</div>
                        <a href="tel:${item.phone}" class="btn-contact">Sotuvchi bilan bog'lanish</a>
                    </div>
                </div>
            `;
        });
    }

    getProducts();
</script>

</body>
</html>

import os
import asyncio
import logging
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import Application, CommandHandler, MessageHandler, CallbackQueryHandler, filters, ContextTypes
from yt_dlp import YoutubeDL
from shazamio import Shazam

# Xatoliklarni kuzatish (Render loglarida ko'rinadi)
logging.basicConfig(format='%(asctime)s - %(name)s - %(levelname)s - %(message)s', level=logging.INFO)

TOKEN = '8717890222:AAEb501qDuzVglFzEKM3wAF-YwbSq9-1jDc'

# Yuklash sozlamalari
YDL_OPTIONS = {
    'format': 'best',
    'outtmpl': 'downloads/%(id)s.%(ext)s',
    'noplaylist': True,
    'quiet': True,
    'no_warnings': True,
}

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "🚀 **Universal Downloader Bot**\n\n"
        "Menga Instagram, TikTok yoki YouTube linkini yuboring.\n"
        "Men videoni yuklayman va musiqasini topib beraman!"
    )

async def handle_video(update: Update, context: ContextTypes.DEFAULT_TYPE):
    url = update.message.text
    if "http" not in url:
        return

    status_msg = await update.message.reply_text("Yuklanmoqda... 📥")
    
    if not os.path.exists('downloads'):
        os.makedirs('downloads')

    try:
        with YoutubeDL(YDL_OPTIONS) as ydl:
            info = ydl.extract_info(url, download=True)
            video_path = ydl.prepare_filename(info)
            
        file_name = os.path.basename(video_path)
        keyboard = [
            [InlineKeyboardButton("🔍 Musiqasini topish", callback_data=f"shazam|{file_name}")]
        ]
        
        with open(video_path, 'rb') as video:
            await update.message.reply_video(
                video=video,
                caption="✅ Yuklab olindi!\n\nMusiqasini bilmoqchi bo'lsangiz, tugmani bosing.",
                reply_markup=InlineKeyboardMarkup(keyboard)
            )
        await status_msg.delete()

    except Exception as e:
        logging.error(f"Yuklashda xato: {e}")
        await status_msg.edit_text("❌ Xatolik! Linkni tekshiring yoki video shaxsiy bo'lishi mumkin.")

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    data = query.data.split("|")
    if data[0] == "shazam":
        file_name = data[1]
        path = os.path.join('downloads', file_name)
        
        if not os.path.exists(path):
            await query.message.reply_text("⚠️ Fayl o'chib ketgan.")
            return

        wait = await query.message.reply_text("🎵 Musiqa tahlil qilinmoqda...")
        
        try:
            shazam = Shazam()
            out = await shazam.recognize_song(path)
            
            if out.get('matches'):
                track = out['track']
                title = track.get('title')
                singer = track.get('subtitle')
                await wait.edit_text(f"🎧 **Topildi!**\n\n📌 Nomi: {title}\n👤 Ijrochi: {singer}")
            else:
                await wait.edit_text("😕 Videodan musiqa topilmadi.")
        except Exception as e:
            logging.error(f"Shazam xatosi: {e}")
            await wait.edit_text("❌ Tahlil qilishda xatolik yuz berdi.")

def main():
    # Render-da port muammosi bo'lmasligi uchun (Background worker sifatida)
    app = Application.builder().token(TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_video))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("Bot Render-da ishga tushdi...")
    app.run_polling()

if __name__ == '__main__':
    main()

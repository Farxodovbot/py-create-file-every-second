
import os
import asyncio
import logging
from telegram import Update
from telegram.ext import ApplicationBuilder, CommandHandler, MessageHandler, filters, ContextTypes
from shazamio import Shazam

# Bot nima qilayotganini terminalda ko'rish uchun
logging.basicConfig(level=logging.INFO)

# SIZNING TOKENINGIZ
TOKEN = "8717890222:AAEb501qDuzVglFzEKM3wAF-YwbSq9-1jDc"

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Salom! Bot Pydroid-da ishlayapti. Musiqa yuboring!")

async def recognize_music(update: Update, context: ContextTypes.DEFAULT_TYPE):
    status = await update.message.reply_text("Tahlil qilinmoqda...")
    try:
        # Faylni yuklab olish
        file = await update.message.voice.get_file() if update.message.voice else await update.message.audio.get_file()
        file_path = "track.ogg"
        await file.download_to_drive(file_path)

        # Shazam orqali aniqlash
        shazam = Shazam()
        out = await shazam.recognize_song(file_path)

        if out['matches']:
            track = out['track']
            title = track.get('title', 'Nomaʼlum')
            artist = track.get('subtitle', 'Nomaʼlum')
            await status.edit_text(f"✅ Topildi!\n\nNom: {title}\nIjrochi: {artist}")
        else:
            await status.edit_text("❌ Afsus, topilmadi.")
        
        if os.path.exists(file_path): os.remove(file_path)
    except Exception as e:
        await status.edit_text(f"Xatolik: {e}")

if __name__ == '__main__':
    app = ApplicationBuilder().token(TOKEN).build()
    app.add_handler(CommandHandler('start', start))
    app.add_handler(MessageHandler(filters.VOICE | filters.AUDIO, recognize_music))
    print("Bot yoqildi! Telegram-ga o'tib tekshiring.")
    app.run_polling()

# --- MA'LUMOTLARNI YUKLASH ---
def load_db(file):
    if not os.path.exists(file):
        with open(file, 'w', encoding='utf-8') as f:
            json.dump({}, f)
        return {}
    with open(file, 'r', encoding='utf-8') as f:
        try: return json.load(f)
        except: return {}

def save_db(data, file):
    with open(file, 'w', encoding='utf-8') as f:
        json.dump(data, f, indent=4, ensure_ascii=False)

anime_db = load_db(DB_FILE)
users_db = load_db(USERS_FILE)

# --- OBUNA NAZORATI ---
def is_subscribed(user_id):
    if int(user_id) == ADMIN_ID: return True
    try:
        status = bot.get_chat_member(CHANNEL_ID, user_id).status
        return status in ['member', 'administrator', 'creator']
    except: return False

def send_sub_msg(chat_id, code=None):
    markup = types.InlineKeyboardMarkup()
    markup.row(types.InlineKeyboardButton("1️⃣ Kanalga a'zo bo'lish ➕", url=CHANNEL_LINK))
    data = f"recheck_{code}" if code else "recheck"
    markup.row(types.InlineKeyboardButton("2️⃣ ✅ Tasdiqlash", callback_query_data=data))
    bot.send_message(chat_id, "👋 **Botdan foydalanish uchun kanalga a'zo bo'ling!**", reply_markup=markup, parse_mode="Markdown")

# --- START HANDLER (Deep Link bilan) ---
@bot.message_handler(commands=['start'])
def start_handler(message):
    uid = str(message.from_user.id)
    if uid not in users_db:
        users_db[uid] = {"name": message.from_user.first_name}
        save_db(users_db, USERS_FILE)

    args = message.text.split()
    code = args[1] if len(args) > 1 else None

    if not is_subscribed(message.from_user.id):
        send_sub_msg(message.chat.id, code)
        return

    if code:
        send_anime_parts(message.chat.id, code)
    elif int(uid) == ADMIN_ID:
        markup = types.InlineKeyboardMarkup(row_width=2)
        markup.add(
            types.InlineKeyboardButton("📊 Statistika", callback_query_data="admin_stats"),
            types.InlineKeyboardButton("📢 Xabar yuborish", callback_query_data="admin_broadcast"),
            types.InlineKeyboardButton("➕ Yangi Anime", callback_query_data="admin_add"),
            types.InlineKeyboardButton("🎬 Qism qo'shish", callback_query_data="admin_add_part"),
            types.InlineKeyboardButton("🚀 Kanalga post", callback_query_data="admin_post")
        )
        bot.send_message(message.chat.id, "🛠 **Admin boshqaruv paneli:**", reply_markup=markup, parse_mode="Markdown")
    else:
        bot.send_message(message.chat.id, "✅ Xush kelibsiz! Anime kodini yuboring.")

# --- CALLBACKS ---
@bot.callback_query_handler(func=lambda call: True)
def callback_inline(call):
    uid = call.from_user.id
    if call.data.startswith("recheck"):
        code = call.data.split("_")[1] if "_" in call.data else None
        if is_subscribed(uid):
            bot.delete_message(call.message.chat.id, call.message.message_id)
            if code: send_anime_parts(call.message.chat.id, code)
            else: bot.send_message(call.message.chat.id, "✅ Tasdiqlandi!")
        else:
            bot.answer_callback_query(call.id, "❌ Obuna bo'lmadingiz!", show_alert=True)
    
    elif call.data.startswith("pv_"):
        _, code, idx = call.data.split("_")
        video_id = anime_db[code]['qismlar'][int(idx)]
        bot.send_video(call.message.chat.id, video_id, caption=f"🎬 {anime_db[code]['nomi']}\n✅ {int(idx)+1}-qism")
        bot.answer_callback_query(call.id)

    elif uid == ADMIN_ID:
        if call.data == "admin_stats":
            bot.send_message(call.message.chat.id, f"👤 A'zolar: {len(users_db)}\n🎬 Animelar: {len(anime_db)}")
        elif call.data == "admin_add":
            msg = bot.send_message(call.message.chat.id, "➕ Anime kodini kiriting:")
            bot.register_next_step_handler(msg, add_code)
        elif call.data == "admin_post":
            msg = bot.send_message(call.message.chat.id, "🚀 Kanalga post (Rasm/Video) yuboring. Kodni yozishni unutmang:")
            bot.register_next_step_handler(msg, prepare_post)

# --- ADMIN FUNKSIYALAR ---
def add_code(message):
    code = message.text
    msg = bot.send_message(message.chat.id, f"Kod {code} uchun nom yuboring:")
    bot.register_next_step_handler(msg, lambda m: finalize_add(m, code))

def finalize_add(message, code):
    anime_db[code] = {"nomi": message.text, "qismlar": []}
    save_db(anime_db, DB_FILE)
    bot.send_message(message.chat.id, f"✅ Saqlandi: {message.text}")

def prepare_post(message):
    codes = re.findall(r'\d+', message.caption if message.caption else (message.text if message.text else ""))
    if not codes:
        bot.send_message(message.chat.id, "❌ Kod topilmadi!")
        return
    code = codes[0]
    markup = types.InlineKeyboardMarkup()
    markup.add(types.InlineKeyboardButton("🍿 Tomosha qilish", url=f"https://t.me/{BOT_USERNAME}?start={code}"))
    bot.copy_message(CHANNEL_ID, message.chat.id, message.message_id, reply_markup=markup)
    bot.send_message(message.chat.id, "✅ Kanalga yuborildi.")

def send_anime_parts(chat_id, code):
    if code in anime_db:
        anime = anime_db[code]
        if not anime['qismlar']:
            bot.send_message(chat_id, "⚠️ Qismlar yo'q.")
            return
        markup = types.InlineKeyboardMarkup(row_width=5)
        btns = [types.InlineKeyboardButton(f"{i+1}", callback_query_data=f"pv_{code}_{i}") for i in range(len(anime['qismlar']))]
        markup.add(*btns)
        bot.send_message(chat_id, f"🎬 **{anime['nomi']}**\nQismlar:", reply_markup=markup, parse_mode="Markdown")

